--- !u!114 &610160112
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 610160107}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0cd2ba4c2c3b32445adbe449f702dd96, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue:
    dialogueLines:
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: Oh hi there!
    - character:
        name: Kitty
        icon: {fileID: 21300000, guid: 7ef8dbeb294a3df4eba8bdd231c284d6, type: 3}
      line: '!!'
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: Sorry for scaring you!
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: 'Wait '
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: You can see me?
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: That means you entered another realm! That happens when you use this
        lift sometimes
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: That also means taking these stairs won't help you escape it
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: All you gotta do is used the lift to go upstairs
    - character:
        name: Morley
        icon: {fileID: 21300000, guid: 894edb549502f894ab5721c7d67239a7, type: 3}
      line: However you will need a key card for that though. Should be around here!
  context: {fileID: 1725207796}
